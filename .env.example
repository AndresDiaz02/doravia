# ── Base de datos ────────────────────────────────────────────────────────────
# Railway provee esta variable automáticamente como DATABASE_URL
DATABASE_URL=postgresql://usuario:contrasena@localhost:5432/doravia

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_seguro_min_32_chars
PORT=3001

# ── DIAN ─────────────────────────────────────────────────────────────────────
# "pruebas_stub" en desarrollo — vacío o "produccion" con PT real contratado
DIAN_MODO=pruebas_stub
# DIAN_PT_URL=https://api.pt-elegido.com
# DIAN_PT_API_KEY=tu_api_key_del_pt
# DIAN_AMBIENTE=2   # 1=produccion, 2=pruebas

# ── Anthropic IA ─────────────────────────────────────────────────────────────
# Requerido para el módulo IA (planes Semilla+)
ANTHROPIC_API_KEY=sk-ant-...

# ── Email transaccional ───────────────────────────────────────────────────────
# Gmail: usar App Password (no la contraseña normal)
# Alternativas: Resend (SMTP), Mailgun, Brevo
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu@gmail.com
SMTP_PASS=tu_app_password
SMTP_FROM="Doravia <noreply@doraviasoft.com>"

# ── Wompi ────────────────────────────────────────────────────────────────────
# Obtener en dashboard.wompi.co
# Sandbox: pub_stagtest_... / prv_stagtest_...
# Producción: pub_prod_... / prv_prod_...
WOMPI_PUB_KEY=pub_stagtest_...
WOMPI_PRV_KEY=prv_stagtest_...
WOMPI_EVENTS_SECRET=stagtest_events_secret_...

# URL a la que Wompi redirige tras el pago (URL del ERP)
APP_URL=https://app.doraviasoft.com

# ── CORS ─────────────────────────────────────────────────────────────────────
# Desarrollo:  http://localhost:5173,http://localhost:5174
# Producción:  https://doraviasoft.com,https://app.doraviasoft.com,https://pos.doraviasoft.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Variables VITE (frontends) ───────────────────────────────────────────────
# Configurar en Netlify como variables de entorno del sitio
# En desarrollo: dejar vacío (el proxy de Vite enruta /api → localhost:3001)
# En producción: URL completa de la API sin trailing slash
VITE_API_URL=https://api.doraviasoft.com

# URL del POS (para el link desde el ERP → abrir POS en nueva pestaña)
VITE_POS_URL=https://pos.doraviasoft.com

# URL del ERP (para el link "volver al ERP" desde el POS)
VITE_ERP_URL=https://app.doraviasoft.com
